# Lumo Hotel Agent env template.
#
# Leave AMADEUS_* unset to run mock-first against the in-memory catalog. The
# façade in lib/amadeus.ts flips to the real Amadeus Self-Service client when
# both CLIENT_ID + CLIENT_SECRET are populated. Amadeus ships a self-serve
# test API (test.api.amadeus.com) that requires no partnership review — once
# you promote to prod, swap base host to api.amadeus.com.

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# test.api.amadeus.com | api.amadeus.com
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Baked into the agent.json manifest so downstream consumers can link back
# to this agent's public origin. Fallback chain in lib/public-base-url.ts.
PUBLIC_BASE_URL=http://localhost:3004
